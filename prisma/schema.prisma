generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")       // transaction pooler — used at runtime
  directUrl = env("DIRECT_URL")         // direct connection — used for migrations only
}

// ─── Resume profile (single row, id="default") ───────────────────────────────

model ResumeProfile {
  id             String   @id @default("default")
  baseResumeKey  String?  // S3 key of the master/base resume PDF
  baseResumeName String?  // original filename, for display
  // Auto-tailoring source of truth: the master LaTeX resume, pasted once on the
  // Resume page. Tailored variants are surgical find/replace edits on this.
  masterTex      String?  @db.Text
  // Truthfulness vocabulary derived from masterTex (tech terms / proper nouns).
  // Cached so every tailor run validates against the same whitelist.
  whitelist      Json?
  // Alternate-identity resume: masterTex with the contact block swapped to the
  // alt email/phone (settings.altIdentity), compiled once. Used for DIRECT
  // applications so the referral and direct candidacies stay independent.
  altResumeKey   String?
  updatedAt      DateTime @updatedAt
}

// ─── App Settings (single row, id="default") ─────────────────────────────────

model AppSettings {
  id        String   @id @default("default")
  data      Json     // merged with config.ts defaults at runtime
  updatedAt DateTime @updatedAt
}

// ─── AI Providers ────────────────────────────────────────────────────────────

model AiProvider {
  id           String   @id @default(cuid())
  name         String
  providerType String   // "openai-compatible" | "anthropic" | "bedrock"
  baseUrl      String
  apiKey       String   // stored as-is (personal tool, no vault needed for v1)
  model        String
  isDefault    Boolean  @default(false)
  isForTailoring Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── LLM usage ledger (one row per successful completion call) ───────────────

model LlmUsage {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  model            String
  purpose          String   // "scoring" | "tailoring" | "tailor_repair" | "post_extraction" | "other"
  promptTokens     Int
  completionTokens Int

  @@index([createdAt])
  @@index([purpose])
}

// ─── Contact (one row per LinkedIn human) ────────────────────────────────────

model Contact {
  id                 String     @id @default(cuid())
  linkedinProviderId String     @unique // Unipile / LinkedIn provider_id — dedup key
  name               String
  title              String?
  company            String?
  linkedinUrl        String
  lastContactedAt    DateTime?  // gate: never re-contact within recontactCooldownDays
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  outreaches         Outreach[]
}

// ─── Job ─────────────────────────────────────────────────────────────────────

model Job {
  id             String     @id @default(cuid())
  source         JobSource
  company        String
  role           String
  jdText         String     @db.Text
  applyUrl       String
  location       String?
  jobProviderId  String?    // source-native id
  sourcePostUrl  String?    // LinkedIn post URL (linkedin_post)
  dedupeKey      String               // normalize(company)+role+location
  applyType      ApplyType

  // Post-specific
  sourcePostAuthorUrl  String?
  sourcePostAuthorName String?
  // Requisition/job ID resolved from the apply link (feed posts that just share
  // an apply URL). Handed to the referrer in the DM so they can submit you.
  externalJobId        String?

  // AI scoring (populated after scoring step)
  aiScore        Int?
  aiReason       String?    @db.Text
  tailoredPitch  String?    @db.Text

  // Salary (LLM-derived + code-normalized)
  salaryMin        Float?
  salaryMax        Float?
  salaryCurrency   String?
  salaryPeriod     SalaryPeriod?
  salaryBasis      SalaryBasis?
  salaryConfidence SalaryConfidence?
  salaryAnnualBase Float?   // normalized annual in owner's base currency

  // Resume tailoring gate (human-in-the-loop)
  needsTailoring       Boolean  @default(false) // AI says base resume should be tailored for this role
  tailoringSuggestions String?  @db.Text        // exact changes the owner should make
  tailoredResumeKey    String?                  // S3 key once a tailored PDF exists (uploaded or auto-generated)
  // Auto-tailoring audit trail: the exact find/replace edits applied to the
  // master .tex for this job, or the failure reason. Owner-visible.
  tailorLog            Json?
  salaryFlagReason     String?

  // Application stage — human-owned
  appStage       AppStage   @default(NEW)
  appStageNote   String?

  // Posting closed — human-owned, distinct from SKIPPED/blacklist. A closed role
  // stays on the board (inside its company card, toggled off) and keeps its
  // contact pool, but no NEW invites/DMs are queued for it. In-flight outreach is
  // re-pitched on the company's best-fit OPEN role at send time (active-role
  // routing). Null = open.
  closedAt       DateTime?
  closedReason   String?

  // Owner's manual ⭐ — pinned jobs sort first on the board and always make the
  // "Apply Today" shortlist regardless of computed priority.
  pinned         Boolean    @default(false)

  // Dual-application strategy: set when the owner confirms they applied
  // DIRECTLY (with the alternate-identity resume), independent of the referral
  // flow. Not a pipeline stage — a referral and a direct application for the
  // same job coexist.
  directAppliedAt DateTime?

  // Outreach state cache — machine-owned, derived from threads
  outreachState  OutreachState @default(NONE)
  // Last time the replenish loop topped up (or attempted to) this job's outreach.
  // Used to back off LinkedIn people-search so we don't re-query every tick.
  lastReplenishAt DateTime?
  // Set the first time the replenish loop determines the candidate pool or invite
  // ceiling is exhausted — gates the one-time "pool exhausted" alert email.
  poolAlertedAt   DateTime?

  // Staleness
  postedAt       DateTime?
  discoveredAt   DateTime   @default(now())

  createdAt      DateTime   @default(now())
  approvedAt     DateTime?
  appliedAt      DateTime?
  updatedAt      DateTime   @updatedAt

  outreaches     Outreach[]

  @@index([appStage])
  @@index([dedupeKey])
  @@index([company])
  @@index([source])
  @@index([createdAt])
}

// ─── Outreach (join: Job ↔ Contact ↔ ChannelThread) ──────────────────────────

model Outreach {
  id        String        @id @default(cuid())
  jobId     String
  contactId String
  threadId  String?       @unique // FK to ChannelThread once started
  role      OutreachRole
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  job     Job     @relation(fields: [jobId], references: [id])
  contact Contact @relation(fields: [contactId], references: [id])
  thread  ChannelThread?  // back-relation; FK (outreachId) lives on ChannelThread

  @@index([jobId])
  @@index([contactId])
}

// ─── ChannelThread (outreach engine — ported from Hirro) ─────────────────────

model ChannelThread {
  id                   String        @id @default(cuid())
  // Link to the outreach join row (replaces Hirro's taskId)
  outreachId           String?       @unique
  outreach             Outreach?     @relation(fields: [outreachId], references: [id])

  status               ThreadStatus  @default(PENDING)
  channel              String        // "linkedin"

  // Account binding — sticky once set
  accountId            String?

  // Unipile identifiers
  providerChatId       String?       // LinkedIn chat_id (DM thread)
  candidateProviderId  String?       // LinkedIn provider_id of the contact

  // Scheduling
  nextActionAt         DateTime?

  // Crash recovery
  pendingSendKey        String?
  pendingSendStartedAt  DateTime?

  // State machine
  providerState        Json?         // { phase: "DRAFT" | "INVITE_PENDING" | "CONNECTED" | "MESSAGED" | ...; connectionNote; firstDm }

  // Sequence progress
  followupsSent        Int           @default(0)
  followupsTotal       Int           @default(1) // first DM counts as send #1; +N followups
  inviteSentAt         DateTime?
  lastMessageAt        DateTime?     // last OUTBOUND send time (followup scheduling anchor)

  // Metrics
  consecutiveFailures  Int           @default(0)
  lastInboundAt        DateTime?

  // Soft-archive (append-only; no hard deletes)
  archivedAt           DateTime?
  archivedReason       String?

  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  messages             ThreadMessage[]

  @@index([status, nextActionAt])
  @@index([providerChatId])
  @@index([candidateProviderId])
}

// ─── ThreadMessage ────────────────────────────────────────────────────────────

model ThreadMessage {
  id                String        @id @default(cuid())
  threadId          String
  direction         MsgDirection
  kind              MessageKind   @default(FIRST_DM) // discriminates invite vs DM for rate-limit counting
  body              String        @db.Text
  providerMessageId String?       // Unipile message_id (dedup)
  sentAt            DateTime      @default(now())

  thread            ChannelThread @relation(fields: [threadId], references: [id])

  @@index([threadId])
  @@index([providerMessageId])
}

// ─── WebhookEvent (dedup table) ──────────────────────────────────────────────

model WebhookEvent {
  id          String   @id  // provider dedup id
  provider    String
  eventType   String
  processedAt DateTime @default(now())

  @@index([processedAt])
}

// ─── CronLock (prevents overlapping cron runs — backlog #24) ──────────────────
// A single row per cron name. `lockedAt` set while a run holds it; cleared on
// finish. A held lock older than the stale window is reclaimable (crash safety).
model CronLock {
  name      String    @id   // "discover" | "tick"
  lockedAt  DateTime?
  updatedAt DateTime  @updatedAt
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum JobSource {
  LINKEDIN_JOB
  LINKEDIN_POST
  ADZUNA
  ATS_WATCHLIST
  REMOTIVE
  REMOTEOK
  JSEARCH
  MANUAL
}

enum ApplyType {
  REFERRAL_FIRST
  MANUAL_NOTIFY
}

enum AppStage {
  NEW          // discovered + scored, passed the gates
  APPROVED     // auto-approved, outreach queued
  OUTREACH     // connection request / DM sent
  REPLIED      // target replied — the goal of a referral tool
  // Post-referral pipeline — human-owned, tracked after a reply lands. Existing
  // outreach threads may keep running; these are never swept by staleness.
  APPLIED      // owner submitted the application
  INTERVIEWING // in the interview loop
  OFFER        // offer received
  SKIPPED      // failed scoring, blacklisted, or stale
}

enum OutreachState {
  NONE
  INVITE_SENT
  CONNECTED
  MESSAGED
  REPLIED
  NO_REPLY_ARCHIVED
}

enum ThreadStatus {
  PENDING
  ACTIVE
  REPLIED
  PAUSED
  ARCHIVED
}

enum MsgDirection {
  OUTBOUND
  INBOUND
}

enum MessageKind {
  INVITE      // connection request (the note)
  FIRST_DM    // first message after connecting
  FOLLOWUP    // subsequent nudge
  INBOUND_MSG // a received reply (recorded for history)
}

enum SalaryPeriod {
  YEAR
  MONTH
  HOUR
}

enum SalaryBasis {
  STATED
  ESTIMATED
}

enum SalaryConfidence {
  HIGH
  MEDIUM
  LOW
}

enum OutreachRole {
  REFERRAL
  RECRUITER
}
