# ─── App ───────────────────────────────────────────────────────────
APP_PASSWORD="change-me"                 # basic auth for dashboard + cron + webhooks
APP_SECRET="change-me-long-random"       # signs email approve/skip tokens
CRON_SECRET="change-me-cron"             # protects /api/cron/* (Vercel sends this as Bearer)
APP_BASE_URL="http://localhost:3000"

# ─── Database ──────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:pass@localhost:5432/job_seeker?schema=public"

# ─── Owner ─────────────────────────────────────────────────────────
OWNER_NAME="Your Name"
OWNER_EMAIL="you@example.com"
OWNER_LINKEDIN_ACCOUNT_ID=""             # Unipile account id

# ─── LLM fallback (providers are managed in the dashboard / AiProvider) ──
OPENAI_API_KEY=""

# ─── Unipile ───────────────────────────────────────────────────────
UNIPILE_DSN=""                           # e.g. api1.unipile.com:13111
UNIPILE_API_KEY=""
UNIPILE_WEBHOOK_SECRET=""

# ─── Adzuna ────────────────────────────────────────────────────────
ADZUNA_APP_ID=""
ADZUNA_APP_KEY=""

# ─── Email (SMTP) ──────────────────────────────────────────────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# ─── AWS S3 (resume storage — Phase 4) ─────────────────────────────
AWS_S3_BUCKET=""
AWS_S3_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# ─── Optional sources ──────────────────────────────────────────────
JSEARCH_RAPIDAPI_KEY=""
